# Server
PORT=5000
NODE_ENV=production

# Database
# Supabase/Postgres is the default runtime for this merged app.
DATABASE_PROVIDER=supabase
MONGODB_URI=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=

# Session
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_NAME=exam_session
JWT_SECRET=replace_with_a_different_long_random_secret

# Admin credentials (change before deployment)
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_admin_password

# Exam settings
EXAM_DURATION_MINUTES=60
EXAM_START_TIME=2024-01-15T09:00:00Z
EXAM_END_TIME=2024-01-15T11:00:00Z
EXAM_ACTIVE=false

# Code execution timeout (ms)
CODE_EXECUTION_TIMEOUT=3000
